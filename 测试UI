-- 优化后的脚本：添加窗口锁定功能，禁止拖动
local Material = loadstring(game:HttpGet("https://raw.githubusercontent.com/heran2k21/-/refs/heads/main/heran01227"))()

-- 获取GUI并锁定的函数
local function lockGUI()
    local success, err = pcall(function()
        -- 尝试多种方式找到并锁定GUI
        local playerGui = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
        
        -- 等待并查找Material GUI
        for _, gui in pairs(playerGui:GetChildren()) do
            if gui:IsA("ScreenGui") and gui.Name:find("Material") then
                -- 禁用拖动功能
                gui.Draggable = false
                
                -- 查找并禁用所有Frame的拖动
                for _, frame in pairs(gui:GetDescendants()) do
                    if frame:IsA("Frame") then
                        frame.Active = false
                        frame.Draggable = false
                        
                        -- 如果存在拖动逻辑，禁用鼠标事件
                        if frame:FindFirstChild("Drag") then
                            frame.Drag:Destroy()
                        end
                        
                        -- 禁用鼠标按钮1事件（通常用于拖动）
                        frame.MouseButton1Down:Disconnect()
                    end
                    
                    -- 禁用ImageButton和TextButton的拖动
                    if frame:IsA("ImageButton") or frame:IsA("TextButton") then
                        frame.Draggable = false
                        frame.MouseButton1Down:Disconnect()
                    end
                end
                
                -- 强制设置属性防止拖动
                gui.ResetOnSpawn = false
                gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
            end
        end
    end)
    
    if not success then
        warn("锁定GUI时出错: " .. tostring(err))
    end
end

